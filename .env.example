VITE_API_BASE_URL=http://127.0.0.1:8000

# Data adapter. Runtime should call the standalone external mock API over HTTP.
# Unit tests override this to mock.
ROUTEPILOT_DATA_SOURCE=external_mock
ROUTEPILOT_EXTERNAL_TRIP_DATA_BASE_URL=http://127.0.0.1:8010
ROUTEPILOT_EXTERNAL_API_TIMEOUT_SECONDS=5

# OpenAI-compatible chat completions configuration.
# Leave ROUTEPILOT_LLM_API_KEY empty for local fallback copy generation.
ROUTEPILOT_LLM_API_KEY=
ROUTEPILOT_LLM_BASE_URL=https://api.openai.com/v1
ROUTEPILOT_LLM_MODEL=gpt-4o-mini

# DashScope compatible-mode configuration. These variables take precedence when set.
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-max-preview
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Streaming governance for real LLM calls.
ROUTEPILOT_STREAM_MAX_CONCURRENT=4
ROUTEPILOT_STREAM_QUEUE_SIZE=64
ROUTEPILOT_STREAM_TIMEOUT_SECONDS=300
ROUTEPILOT_STREAM_HEARTBEAT_SECONDS=15
